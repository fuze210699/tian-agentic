{
  "name": "tian-vue-annotate",
  "version": "0.1.0",
  "description": "Click-to-annotate visual feedback toolbar for Vue 3 apps, for pasting structured feedback into AI coding agents.",
  "type": "module",
  "main": "./dist/tian-vue-annotate.umd.cjs",
  "module": "./dist/tian-vue-annotate.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "webpack.cjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/tian-vue-annotate.es.js",
      "require": "./dist/tian-vue-annotate.umd.cjs",
      "module": "./dist/tian-vue-annotate.es.js",
      "default": "./dist/tian-vue-annotate.umd.cjs"
    },
    "./vite": {
      "require": "./dist/vite.cjs",
      "import": "./dist/vite.cjs"
    },
    "./webpack": {
      "require": "./webpack.cjs",
      "import": "./dist/webpack.cjs"
    },
    "./webpack.cjs": "./webpack.cjs",
    "./style.css": "./dist/style.css"
  },
  "peerDependencies": {
    "vue": "^3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vue": "^3.3",
    "vue-tsc": "^2.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node build-plugin.mjs",
    "typecheck": "vue-tsc --noEmit",
    "test:e2e": "node tests/e2e/run.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "license": "PolyForm-Noncommercial-1.0.0",
  "keywords": [
    "vue",
    "vue3",
    "annotation",
    "ai-agents",
    "developer-tools"
  ]
}
